---
import Layout from "../layout/layout.astro";
import Knap from '../components/buttons.astro'
import Plusknap from '../components/plusbutton.astro'
import Card from '../components/productCard.astro'
import "../styles/global.css"

//Supabase-oplysninger hentes fra import.meta.env//
const url = `${import.meta.env.SUPABASE_URL}/rest/v1/eksamen?select=*&id=in.(27,35,36,49)&order=id.asc` /*** Får produkterne i rækkefølge "order=id.asc" og vælger kun specifikke produkter "id=in.(27,35,36,49)"***/
const apiKey = import.meta.env.SUPABASE_PUBLISHABLE_KEY;

const options = {
  //API-nøglen sendes med i headers//
  headers: {
    apikey: apiKey,
  },
};

//Koden kører i Astro frontmatter await fetch() erstatter getData()//
const data = await fetch(url, options).then((res) => res.json());
//data kan bagefter bruges direkte i HTML-delen//
console.log(data); 
---
<Layout>
<img src="/img/forside.webp" alt="forsidebillede">

<h2>Udforsk vores nyheder</h2>

<Card eksamen={data[0]}/>
<Card eksamen={data[1]}/>
<Card eksamen={data[2]}/>
<Card eksamen={data[3]}/>

 <div class="prikker">
  <span></span>
  <span></span>
   <span class="aktiv"></span>
  <span></span>
  <span></span>
</div>

