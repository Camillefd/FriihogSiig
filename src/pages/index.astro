<!-- JavaScript (bruges kun til karusellen) -->
<script>
  /* Finder alle produktkort i karusellen */
  const slides = document.querySelectorAll('.karusel-slide');
  
  /* Finder alle prikker i bunden */
  const dots = document.querySelectorAll('.prikker span');
  
  /* Starter på det andet kort (kort nr. 1 = 0, derfor andet kort = 1) */
  let aktivt = 1;

function opdater() {
    /* Går igennem alle slides og opdaterer udseendet */
    slides.forEach((slide, i) => {
      /* Tilføjer klassen 'aktiv' til det aktive slide og fjerner den fra de andre */
      slide.classList.toggle('aktiv', i === aktivt);
    });

    /* Går igennem alle prikker og sætter den aktive klasse på den prik der matcher det aktive slide */
    dots.forEach((dot, i) => {
      dot.classList.toggle('aktiv', i === aktivt);
    });
  }

  /* Når man klikker på venstre pil går man et slide tilbage "% slides.length" sørger for at den starter forfra når man når slutningen */
  document.querySelector('.karusel-btn.tildigere').addEventListener('click', () => {
    aktivt = (aktivt - 1 + slides.length) % slides.length;
    opdater();
  });

  /* Når man klikker på højre pil går man et slide frem */
  document.querySelector('.karusel-btn.next').addEventListener('click', () => {
    aktivt = (aktivt + 1) % slides.length;
    opdater();
  });

  /* Køre "opdater" første gang så karusellen starter rigtigt */
  opdater();
</script>