---
//@ts-nocheck
export const prerender = false; // Siden bliver bygget når man trykker på den, frem for på forhold som Astro plejer.

import Layout from "../../layout/layout.astro";
import Knap from "../../components/buttons.astro";
import Plusknap from "../../components/plusbutton.astro";
import Skp from "../../components/sidstKiggetPaa.astro";
import Card from "../../components/productCard.astro";
import "../../styles/global.css";
import Breadcrumb from "../../components/breadcrumb.astro";

// Henter id fra URL'en
const { id } = Astro.params;
const showOenskeSkyen = true;

//Supabase-oplysninger hentes fra import.meta.env//
const apiKey = import.meta.env.SUPABASE_PUBLISHABLE_KEY;

const options = {
  //API-nøglen sendes med i headers//
  headers: {
    apikey: apiKey,
  },
};

//Koden kører i Astro frontmatter await fetch() erstatter getData()//
const url = `${import.meta.env.SUPABASE_URL}/rest/v1/eksamen?id=eq.${id}&select=*`;
const data = await fetch(url, options).then((res) => res.json());
const produkt = data[0]; // Henter det første (og eneste) produkt fra arrayet

// Henter 2 produkter til "Sidst kigget på"
const skpUrl = `${import.meta.env.SUPABASE_URL}/rest/v1/eksamen?select=*&order=id.asc`;
const skpData = await fetch(skpUrl, options).then((res) => res.json());

// Henter 4 produkter til "Mix and match"
const mmUrl = `${import.meta.env.SUPABASE_URL}/rest/v1/eksamen?select=*&order=id.asc&limit=4`;
const mmData = await fetch(mmUrl, options).then((res) => res.json());
---

<Layout>
  <section class="toppen">
    <Breadcrumb jewellery={produkt.produktnavn} id={produkt.id} />

    <div class="singleproduct">
      <!-- Billeder -->
      <div class="billeder-sektion">
        <button class="pil-venstre"><img src="/img/ikoner/pil-v.svg" alt="tidligere" /></button>
        <img id="firstbillede" src={`/img/${produkt.billede1}`} alt={produkt.produktnavn} />
        <button class="pil-hoejre"><img src="/img/ikoner/pil-h.svg" alt="næste" /></button>

        <div class="thumbnails">
          {produkt.billede1 && <img src={`/img/${produkt.billede1}`} alt="billede1" />}
          {produkt.billede2 && <img src={`/img/${produkt.billede2}`} alt="billede2" />}
          {produkt.billede3 && <img src={`/img/${produkt.billede3}`} alt="billede3" />}
          {produkt.billede4 && <img src={`/img/${produkt.billede4}`} alt="billede4" />}
        </div>
      </div>

      <!-- Info om produktet-->
      <div class="info">
        <h1>{produkt.produktnavn}</h1>
        <p>{produkt.pris} kr</p>
        <p>{produkt.k_beskrivelse}</p>
        <p>Farve/Matriale:</p>
        <Knap tekst={produkt.farve} href="" type="orange" />
        <div class="kurvogantal">
          <Knap tekst="Tilføj til kurv" href="" type="blaa" />
          <div class="antal">
            <button><img src="/img/ikoner/minus-b.svg" alt="blå minus" /></button>
            <span><p>1</p></span>
            <button><img src="/img/ikoner/plus-b.svg" alt="blå plus" /></button>
          </div>
        </div>
 {
  showOenskeSkyen && (
    <a class="sky" href={`/product-details/${produkt.id}`}>
      <img class="button-logo" src="/img/ikoner/oenskeskyen.svg" alt="" />
      Tilføj til ønskeskyen
    </a>
  )
}
      </div>
    </div>
  </section>

  <!-- Mix and match -->
  <section class="mixmatch">
    <h2>Mix and match</h2>
    <div class="scrollcontainer">
      {mmData.map((produkt) => <Card eksamen={produkt} />)}
    </div>
  </section>

  <!-- Specifikationer -->
  <section class="specifikationer">
    <h2>Specifikationer</h2>
    <p>{produkt.l_beskrivelse}</p>
  </section>

  <img class="udklip" src="/img/udklip.webp" alt="udklip" />

  <!-- Materialer -->
  <section class="materialer">
    <h2>Materialer</h2>
    <p>{produkt.materiale}</p>
  </section>

  <!-- Størrelsesguide -->
  <section class="stoerrelsesguide">
    <div>
      <h2>Størrelsesguide</h2>
      <p>Er du i tvivl om størrelsen? Bare rolig — til højre finder du vores størrelsesguide, som hjælper dig med at finde det rette mål. Har du stadig spørgsmål, er du altid velkommen til at række ud til os eller besøge en af vores forhandlere.</p>
    </div>
    <div>
      <img src="/img/strg.webp" alt="størrelsesguide" />
    </div>
  </section>

  <!-- Sidst kigget på -->
  <section class="skp">
    <Skp eksamen1={skpData[1]} eksamen2={skpData[2]} />
  </section>
</Layout>

<!-- CSS -->
<style>
  /**  Info om produktet **/
  .singleproduct {
    display: flex;
    gap: 40px;
  }

  .toppen {
    padding: 40px;
    margin-bottom: 90px;
  }

  .billeder-sektion {
    display: flex;
    flex-direction: column;
    position: relative;
    flex: 1; /** Billederne må fylde den plads ud, der er tilbage inde i billeder-sektion **/
  }

  #firstbillede {
    width: 100%;
  }

  .thumbnails {
    display: flex;
    gap: 10px;
    margin-top: 10px;
  }

  .thumbnails img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    cursor: pointer;
  }

  .pil-venstre,
  .pil-hoejre {
    position: absolute;
    top: 50%; /** Flytter pilene 50% ned i forhold til billedet (parent-elementet) **/
    transform: translateY(-100%); /** Flytter pilene op igen med 100% af dets egen højde **/
    background: none;
    border: none;
    z-index: 2; /** Sørger for at pilen ligger ovenpå alle andre ting **/
  }

  .pil-venstre {
    left: -30px;
  }

  .pil-hoejre {
    right: -30px;
  }

  .pil-venstre:hover,
  .pil-hoejre:hover {
    background-color: var(--color-text);
    border-radius: 8px;
  }

  .info {
    flex: 1; /** Info må fylde den plads ud, der er tilbage inde i billeder-sektion **/
    display: flex;
    flex-direction: column; /** stablet lodret **/
    gap: 15px;
  }

  .info :global(.blaa) {
    /** Fanger den inde i komponenten **/
    width: auto;
    padding: 15px 30px;
  }

  .info :global(.orange) {
    /** Fanger den inde i komponenten **/
    width: 180px;
    padding: 15px 70px;
    margin-bottom: 50px;
  }

  .kurvogantal {
    display: flex;
    align-items: center;
    gap: 15px;
    padding-top: 30px;
    padding-bottom: 15px;
  }

  .antal {
    display: flex;
    gap: 0.8rem;
    align-items: center;
  }

  .antal button,
  .antal span {
    width: 50px;
    height: 50px;
    padding: 15px;
    border: 1px solid var(--color-blue);
    background: transparent;
    border-radius: 8px;
    display: grid;
    place-items: center;
  }

  .antal button {
    cursor: pointer;
  }

  .sky {
    display: flex;
    align-items: center;
    gap: 10px;
    background-color: #008fb4;
    padding: 10px 20px;
    text-decoration: none;
    color: #fff;
    font-weight: bold;
    justify-content: center;
    border-radius: 10px;
    width: 25rem;
  }

  .button-logo {
    width: 20px;
    height: 20px;
  }

  /**  Mix and match **/
  .mixmatch {
    background-color: var(--color-text);
    padding: 40px;
    display: flex;
  }

  .mixmatch h2 {
    color: var(--color-background);
    margin-bottom: 20px;
    right: 3rem;
    top: 25rem;
    writing-mode: vertical-rl; /**  Vender teksten så man læser den oppefra og ned **/
    padding: 30px 50px 30px 30px;
  }

  .mixmatch :global(h3),
  .mixmatch :global(p) {
    color: var(--color-background);
  }

  .scrollcontainer {
    display: flex;
    gap: 20px;
    overflow-x: scroll; /** Når indholdet bliver for bredt vandret, så laver den en scrollbar **/
    padding: 40px;
  }

  .scrollcontainer::-webkit-scrollbar {
    height: 4px;
  }

  .scrollcontainer::-webkit-scrollbar-track {
    background: #f2e3c83c;
  }

  .scrollcontainer::-webkit-scrollbar-thumb {
    background: var(--color-background);
    border-radius: 10px;
  }

  .specifikationer {
    margin: 80px;
  }

  .specifikationer h2 {
    padding-bottom: 30px;
  }

  .udklip {
    position: absolute; /** Bliver taget ud af det "normale" layout og kan placeres præcist **/
    width: 500px;
    left: 800px;
    top: 115rem;
  }

  /** Materialer **/
  .materialer {
    padding: 80px;
    background-color: var(--color-blue);
  }

  .materialer h2,
  .materialer p {
    color: var(--color-background);
  }

  .materialer h2 {
    padding-bottom: 30px;
  }

  /** Størrelsesguide **/
  .stoerrelsesguide {
    display: flex;
    padding: 80px;
  }

  .stoerrelsesguide h2 {
    padding-bottom: 30px;
  }

  .stoerrelsesguide p {
    padding-right: 80px;
  }

  @media (max-width: 768px) {
    /**  Info om produktet **/
    .toppen {
      margin-bottom: 0;
    }

    .singleproduct {
      flex-direction: column; /** stablet lodret **/
    }

    .pil-venstre {
      left: -8%;
    }

    .pil-hoejre {
      right: -8%;
    }

    .info :global(.orange) {
      width: 135px;
      padding: 15px 50px;
      margin-bottom: 0;
    }

    .sky {
      width: 22rem;
      margin: 12px;
    }

    /**  Mix and match **/
    .mixmatch {
      display: block;
    }

    .mixmatch h2 {
      margin-bottom: 10px;
      writing-mode: unset; /** Fordi den skal stå vandret i mobil **/
      padding: 10px 0 10px 10px;
    }

    .scrollcontainer {
      padding: 0;
    }

    /**  Specifikationer, materialer og størrelsesguide **/
    .specifikationer {
      margin: 40px;
    }

    .specifikationer h2,
    .materialer h2,
    .stoerrelsesguide h2,
    .stoerrelsesguide p {
      padding-bottom: 20px;
    }

    .udklip {
      display: none;
    }

    .materialer,
    .stoerrelsesguide {
      padding: 40px;
    }

    .stoerrelsesguide {
      display: block;
    }

    .skp {
      padding-bottom: 50px;
    }
  }
</style>
