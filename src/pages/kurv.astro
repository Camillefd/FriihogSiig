---
import Layout from "../layout/layout.astro";
import KurvItems from "../components/kurvItems.astro";
import Ordreoversigt from "../components/ordreoversigt.astro";
import Leveringsoplysninger from "../components/leveringsoplysninger.astro";

//Supabase-oplysninger hentes fra import.meta.env//
const url = `${import.meta.env.SUPABASE_URL}/rest/v1/eksamen?select=*`;
const apiKey = import.meta.env.SUPABASE_PUBLISHABLE_KEY;

const options = {
//API-nøglen sendes med i headers//
headers: {
apikey: apiKey,
},
};

//Koden kører i Astro frontmatter await fetch() erstatter getData()//
const data = await fetch(url, options)
.then((res) => res.json());
//data kan bagefter bruges direkte i HTML-delen//
---

<Layout title="Kurv">

  <main class="kurv-side">

    <section class="kurv-layout">

      <KurvItems data={data} />

      <Ordreoversigt data={data} />

    </section>

    <Leveringsoplysninger />

  </main>

</Layout>