<style>
   .omfs-page {
  background-color: #1b0f4f;
}

.hero-image img {
  width: 100%;
  height: 600px;

  object-fit: cover;
object-position: center 75%;

  display: block;
}

.vores-historie {
  background-color: #f8ead3;
  padding: 4rem 1.5rem;
  position: relative;
}

.vores-historie h2 {
  font-size: 3rem;
  font-weight: 300;
  color: #7b3f3f;
  margin-bottom: 2rem;
}

.historie-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  max-width: 1100px;
  margin: 0 auto;
}

.historie-tekst {
  color: #7b3f3f;
  line-height: 1.8;
  font-size: 1rem;
}

.historie-tekst p {
  margin-bottom: 2rem;
}

.find-butik {
  position: relative;
  padding: 4rem 1.5rem;
  color: #f8ead3;
}

.find-butik h1 {
  font-size: 3rem;
  font-weight: 300;
  color: #f3e3c8;
  margin-bottom: 2rem;
}

.store-search {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-top: 2rem;
  max-width: 400px;
}

.store-search input {
  width: 100%;
  padding: 0.8rem 1.5rem;
  border-radius: 6px;
  border: none;
  background-color: #8d83a8;
  color: white;
}

.store-search input::placeholder {
  color: #1b0f4f;
  font-family: garamond;
  font-size: medium;
}

.store-search .button,
.button2 {
  border: none;
  border-radius: 6px;
  padding: 0.8rem 2rem;
}

.store-list {
  max-width: 700px;
  margin-top: 3rem;
}

.store-list article {
  border-bottom: 1px solid #f8ead3;
  padding: 2rem 0;
}

.store-list h2 {
  font-size: 1.5rem;
  font-weight: 300;
  color: #f3e3c8;
}

.store-list p {
  margin: 0.2rem 0;
  color: #f3e3c8;
}

.button2 {
  margin-top: 2rem;
}

.reviews {
  background-color: #f3e3c8;
  padding: 5rem 1.5rem 6rem;
  text-align: center;
  overflow: hidden;
}

.reviews h2 {
  color: #7b3f3f;
  font-size: 2.5rem;
  font-weight: 300;
  margin-bottom: 3rem;
}

.review-carousel {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
}

.review-track {
  display: flex;
  align-items: center;
  gap: 1rem;
  width: 100%;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scrollbar-width: none;
  padding: 1rem;
  min-height: 330px;
  justify-content: center;
}

.review-track::-webkit-scrollbar {
  display: none;
}

.review-slide {
  flex: 0 0 75%;
  scroll-snap-align: center;
  opacity: 0.55;
  transform: scale(0.85);
  transition: transform 1.4s ease, opacity 1.4s ease;
  transform-origin: center center;
  will-change: transform;
  backface-visibility: hidden;
}

.review-slide.active {
  opacity: 1;
  transform: scale(1);
}

.review-slide img {
  width: 100%;
  display: block;
  border-radius: 4px;
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
}

.carousel-btn {
  background: none;
  border: none;
  color: #7b3f3f;
  font-size: 3rem;
  cursor: pointer;
}

.dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.7rem;
  margin-top: 2rem;
}

.dots span {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background-color: #7b3f3f;
  opacity: 0.8;
  transition: all 0.3s ease;
}

.dots span.active {
  width: 24px;
  height: 24px;
  background-color: #ff955f;
  opacity: 1;
}

@media (min-width: 900px) {
  .vores-historie {
    padding: 6rem 5rem;
  }

  .vores-historie h2 {
    position: absolute;
    left: 3rem;
    top: 6rem;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 5rem;
    margin-bottom: 0;
  }

  .historie-grid {
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    margin-left: 10rem;
  }

  .historie-tekst {
    line-height: 2.2;
    font-size: 1.2rem;
  }

  .find-butik {
    padding: 4rem;
    min-height: 850px;
  }

  .find-butik h1 {
    position: absolute;
    right: 3rem;
    top: 25rem;
    writing-mode: vertical-rl;
    font-size: 5rem;
    margin-bottom: 0;
  }

  .store-search {
    flex-direction: row;
    gap: 2rem;
    max-width: none;
  }

  .store-search input {
    width: 300px;
  }

  .store-list h2 {
    font-size: 1.7rem;
  }

  .reviews {
    padding: 7rem 0 8rem;
  }

  .reviews h2 {
    font-size: 4rem;
    margin-bottom: 4rem;
  }

  .review-carousel {
    gap: 3rem;
  }

  .review-track {
    gap: 2rem;
    width: 900px;
    padding: 2rem 220px;
    min-height: 500px;
  }

  .review-slide {
    flex: 0 0 460px;
    transform: scale(0.7) translateY(-160px);
  }

  .review-slide.active {
    flex-basis: 460px;
    transform: scale(1) translateY(0);
  }

  .carousel-btn {
    font-size: 5rem;
  }

  .dots span {
    width: 14px;
    height: 14px;
  }

  .dots span.active {
    width: 28px;
    height: 28px;
  }
}
</style>

<script is:inline>
  const slides = document.querySelectorAll(".review-slide");
  const dots = document.querySelectorAll(".dots span");
  const prevBtn = document.querySelector(".carousel-btn.prev");
  const nextBtn = document.querySelector(".carousel-btn.next");

  let currentIndex = 2;

  function updateCarousel(shouldScroll = false) {
    slides.forEach((slide, index) => {
      slide.classList.toggle("active", index === currentIndex);
    });

    dots.forEach((dot, index) => {
      dot.classList.toggle("active", index === currentIndex);
    });

    if (shouldScroll) {
      slides[currentIndex].scrollIntoView({
        behavior: "smooth",
        inline: "center",
        block: "nearest"
      });
    }
  }

  nextBtn.addEventListener("click", () => {
    currentIndex = (currentIndex + 1) % slides.length;
    updateCarousel(true);
  });

  prevBtn.addEventListener("click", () => {
    currentIndex = (currentIndex - 1 + slides.length) % slides.length;
    updateCarousel(true);
  });

  updateCarousel(false);
</script>