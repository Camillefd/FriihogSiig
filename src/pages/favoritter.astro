---
const { footerClass } = Astro.props;
import Footer from "../components/footer.astro";
import Header from "../components/menu.astro";
import ProductCard from "../components/productCard.astro";
import Layout from "../layout/layout.astro";

//Supabase-oplysninger hentes fra import.meta.env//
const url = `${import.meta.env.SUPABASE_URL}/rest/v1/eksamen?select=*`;
const apiKey = import.meta.env.SUPABASE_PUBLISHABLE_KEY;

const options = {
  //API-nøglen sendes med i headers//
  headers: {
    apikey: apiKey,
  },
};

//Koden kører i Astro frontmatter await fetch() erstatter getData()//
const data = await fetch(url, options).then((res) => res.json());
console.log("data", data);

//data kan bagefter bruges direkte i HTML-delen//
---

<Layout title="Dine Favoritter">
  <section class="favoritter-side">
    <h1>Dine Favoritter</h1>
    <div class="favoritter-grid">
      {
        data.map((produkt: any) => {
          return <ProductCard eksamen={produkt} isHeartShown={false} showOenskeSkyen={true} />;
        })
      }
    </div>
  </section>
</Layout>

<style>
  .favoritter-side {
    padding: 0 113px;
  }

  .favoritter-grid {
    display: grid;
    grid-template-columns: repeat(3, max-content);

    justify-content: space-between;
  }
</style>
