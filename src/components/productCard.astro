---
// Henter eksamen-data der er sendt med fra index //
const { eksamen } = Astro.props;
import Plusknap from './plusbutton.astro';
console.log(eksamen); 
---

<article>
    <div class="productcard">
        <div class="billeder">
            <img class="farvorit" src="/img/ikoner/hjerte.svg" alt="farvorit"> 
            <a href="/src/pages/singleproduct">
                <img class="produktbillede" src={`/img/${eksamen.billede1}`} alt={eksamen.produktnavn}>
            </a>
            <div class="plusplacering">
                <Plusknap href="/kurv" />
            </div>
        </div>
        <h3>{eksamen.produktnavn}</h3>
        <p>{eksamen.pris} kr</p>
    </div>
</article>

<style>
    .productcard {
    display: flex;
    flex-direction: column;
    padding-top: 70px;
}

h3,
p {
    padding-bottom: 10px;
}

.billeder{
    position: relative;
       width: fit-content;
   
}


.produktbillede {
    width: 310px;
    height: 310px;
    object-fit: cover;
}

.farvorit {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 25px;
    height: 25px;
}

.plusplacering {
   position: absolute;
    bottom: 1px;
    right: 0px;
}

@media (max-width: 768px) {
h3,
p {
    padding-bottom: 5px;
}

.billeder{
    position: relative;
    width: fit-content;
  padding-bottom: 2px;
}

.produktbillede {
    width: 200px;
    height: 200px;
    object-fit: cover;
}

.plusplacering {
    bottom: 10px;
}

  .productcard {
  margin-bottom: 10px;  
  padding-top: 0px;
}
}

</style>
