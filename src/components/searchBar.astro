<section class="search-section" id="searchSection">
  <form class="search-form">
    <input type="search" placeholder="Søg efter..." />
    <button type="submit">Søg</button>
  </form>
</section>

<style>
.search-section {
  background-color: #f3e3c8;
  padding: 0 1rem;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s ease, padding 0.5s ease;
}

.search-section.open {
  max-height: 220px;
  padding: 1.5rem 1rem 2rem;
}

.search-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  align-items: stretch;
}

.search-form input {
  width: 100%;
  padding: 0.8rem 1.2rem;
  border: none;
  border-radius: 8px;
  background-color: #cdb4a3;
  color: #7b3f3f;
  font-size: 1rem;
  font-family: inherit;
}

.search-form input::placeholder {
  color: #7b3f3f;
}

.search-form button {
  width: 100%;
  padding: 0.8rem 1.5rem;
  border: none;
  border-radius: 8px;
  background-color: #7b3f3f;
  color: #f8ead3;
  font-size: 1rem;
  font-family: inherit;
  cursor: pointer;
}

.search-icon {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}

.search-icon img {
  width: 28px;
  height: 28px;
  display: block;
}

/* DESKTOP */
@media (min-width: 900px) {
  .search-section {
    padding: 0 5rem;
  }

  .search-section.open {
    max-height: 180px;
    padding: 2.5rem 5rem 3rem;
  }

  .search-form {
    flex-direction: row;
    gap: 3rem;
    align-items: center;
  }

  .search-form input {
    flex: 1;
    width: auto;
    padding: 0.5rem 2rem;
    font-size: 2rem;
  }

  .search-form button {
    width: auto;
    padding: 0.5rem 3.5rem;
    font-size: 2rem;
  }
}
</style>

<script is:inline>
  const searchIcon = document.querySelector(".search-icon");
  const searchSection = document.querySelector("#searchSection");

  searchIcon?.addEventListener("click", () => {
    searchSection?.classList.toggle("open");
  });
</script>