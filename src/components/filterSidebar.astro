---
// Filter.astro
// header.css
---

<div class="filtre">
  <div class="filter-box">
    <div class="filter-header">
      <h3>Filter</h3>
    </div>

    <div class="filter-content">
      <div class="price-range">
        <input type="text" placeholder="kr." />
        <span>til</span>
        <input type="text" placeholder="kr." />
      </div>

      <div class="accordion">
        <button class="accordion-header">
          Farve
          <span>⌄</span>
        </button>

        <div class="accordion-content">
          <label><input type="checkbox" /> Guld</label>
          <label><input type="checkbox" /> Sølv</label>
          <label><input type="checkbox" /> Perler</label>
        </div>
      </div>

      <div class="accordion">
        <button class="accordion-header">
          Kampagne
          <span>⌄</span>
        </button>

        <div class="accordion-content">
          <label><input type="checkbox" /> Udsalg</label>
          <label><input type="checkbox" /> Nyheder</label>
        </div>
      </div>

      <button class="apply-btn">Anvend</button>
    </div>
  </div>
</div>

<script>
  const accordions = document.querySelectorAll(".accordion");
  const filterHeader = document.querySelector(".filter-header");

  accordions.forEach((accordion) => {
    const header = accordion.querySelector(".accordion-header");

    header?.addEventListener("click", () => {
      accordion.classList.toggle("active");
    });
  });

  filterHeader?.addEventListener("click", () => {
    filterHeader.classList.toggle("active");
  });
</script>

<style>
  .filter-box:has(.filter-header.active) {
    background: var(--color-background);
    padding: 2rem;
    border: 1px solid var(--color-text);
    max-width: 400px;
    font-family: serif;
  }

  .filtre {
    display: flex; /* Starter flexboxen så indholdet kan rykkes rundt */
    justify-content: flex-end; /* Skubber indholdet helt til højre */
    margin-right: 80px;
    margin-bottom: 2rem;
  }

  .filter-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 2rem;
    cursor: pointer;
  }

  .filter-header.active {
    margin-right: unset;
  }

  .filter-content {
    display: none;
  }

  .filter-header.active ~ .filter-content {
    display: block;
  }

  .filter-header h3 {
    color: var(--color-blue)
    font-size: 1.2rem;
  }

  .price-range {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .price-range input {
    background: color-mix(in srgb, var(--color-text) 25%, transparent);
    border: none;
    padding: 1rem;
    width: 100%;
    border-radius: 8px;
    font-size: 1rem;
  }

  .accordion {
    border-top: 1px solid var(--color-text);
  }

  .accordion:last-of-type {
    border-bottom: 1px solid var(--color-text);
  }

  .accordion-header {
    width: 100%;
    background: none;
    border: none;
    padding: 1.2rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1rem;
    color: var(--color-text);
    cursor: pointer;
  }

  .accordion-content {
    display: none;
    padding-bottom: 1rem;
    flex-direction: column;
    gap: 0.5rem;
  }

  .accordion.active .accordion-content {
    display: flex;
  }

  .apply-btn {
    display: block;
    margin: 2rem auto 0;
    background: var(--color-text);
    color: var(--color-background);
    border: none;
    padding: 1rem 3rem;
    border-radius: 8px;
    font-size: 1.2rem;
    cursor: pointer;
  }

  label {
    display: flex;
    gap: 0.5rem;
    color: var(--color-text);
  }
  @media screen and (max-width: 768px) {
    .filter-box:has(.filter-header.active) {
      width: 100%;
      max-width: unset;
    }

    .filtre {
      margin-right: 50px;
    }

    .filtre:has(.filter-header.active) {
      margin-right: unset;
      padding: 0 1rem;
    }
  }
</style>
